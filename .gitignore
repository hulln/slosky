# Ignore all large output files (jsonl, sqlite, csv, meta.json) in outputs/
outputs/**/*.jsonl
outputs/**/*.sqlite
outputs/**/*.csv
outputs/**/*.meta.json
.venv/
.venv-annot/
__pycache__/
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
cache/
models/
tmp/
*.pyc
*.pyo
*.swp
*.swo
.DS_Store

.vscode/
.claude/
.codex/

